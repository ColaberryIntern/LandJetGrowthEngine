# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/landjet_growth_engine

# Server
NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=1h

# Email (Mandrill)
MANDRILL_API_KEY=
EMAIL_FROM=noreply@landjet.com

# Fallback SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Voice (Synthflow)
SYNTHFLOW_API_KEY=
SYNTHFLOW_INTEREST_AGENT_ID=
SYNTHFLOW_WELCOME_AGENT_ID=
ENABLE_VOICE_CALLS=false

# SMS (GoHighLevel)
GHL_API_KEY=

# Lead Intelligence (Apollo)
APOLLO_API_KEY=

# AI (OpenAI)
OPENAI_API_KEY=
AI_MODEL=gpt-4o
AI_MAX_TOKENS=2048

# Campaign Defaults
CAMPAIGN_TEST_EMAIL_DOMAIN=test.landjet.com
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
